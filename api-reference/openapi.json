{
  "openapi": "3.1.0",
  "info": {
    "title": "LeuwongRR User API",
    "version": "1.0.0",
    "description": "Dokumentasi publik LeuwongRR User API. API ini hanya untuk akses data milik user/member sendiri menggunakan User API Token."
  },
  "servers": [
    {
      "url": "https://leuwongrr.online",
      "description": "Production"
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "Endpoint public untuk mengecek status API."
    },
    {
      "name": "User",
      "description": "Endpoint khusus user/member dengan User API Token."
    },
    {
      "name": "Orders",
      "description": "Endpoint untuk membaca order milik user sendiri."
    },
    {
      "name": "Invoices",
      "description": "Endpoint untuk membaca invoice milik user sendiri."
    }
  ],
  "components": {
    "securitySchemes": {
      "userBearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "User API Token",
        "description": "Gunakan User API Token dari halaman /user/api-access."
      }
    },
    "schemas": {
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "OK"
          },
          "data": {
            "type": "object"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "message": {
            "type": "string",
            "example": "Unauthorized API token."
          }
        }
      },
      "UserProfile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "Daddy"
          },
          "email": {
            "type": "string",
            "example": "user@example.com"
          }
        }
      },
      "InvoiceStatus": {
        "type": "object",
        "properties": {
          "invoice_code": {
            "type": "string",
            "example": "INV20260429113629619"
          },
          "type": {
            "type": "string",
            "example": "order"
          },
          "payment_status": {
            "type": "string",
            "example": "paid"
          },
          "amount": {
            "type": "number",
            "example": 348
          }
        }
      }
    }
  },
  "paths": {
    "/api/v1/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Check API health",
        "description": "Endpoint public untuk mengecek apakah LeuwongRR User API aktif.",
        "security": [],
        "responses": {
          "200": {
            "description": "API aktif",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                },
                "example": {
                  "success": true,
                  "message": "OK",
                  "data": {
                    "service": "LeuwongRR REST API v1",
                    "enabled": true
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/me": {
      "get": {
        "tags": [
          "User"
        ],
        "summary": "Get current user",
        "description": "Mengambil informasi akun user berdasarkan User API Token.",
        "security": [
          {
            "userBearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "User ditemukan",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                },
                "example": {
                  "success": true,
                  "message": "OK",
                  "data": {
                    "user": {
                      "id": 1,
                      "name": "Daddy",
                      "email": "user@example.com"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Token tidak valid atau tidak dikirim",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "message": "Unauthorized API token."
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/me/orders": {
      "get": {
        "tags": [
          "Orders"
        ],
        "summary": "List own orders",
        "description": "Mengambil daftar order milik user pemilik token.",
        "security": [
          {
            "userBearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Daftar order user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                },
                "example": {
                  "success": true,
                  "message": "OK",
                  "data": {
                    "orders": []
                  }
                }
              }
            }
          },
          "401": {
            "description": "Token tidak valid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/me/orders/{invoice}": {
      "get": {
        "tags": [
          "Orders"
        ],
        "summary": "Get own order",
        "description": "Mengambil detail order berdasarkan nomor invoice. Hanya bisa membaca order milik user pemilik token.",
        "security": [
          {
            "userBearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "invoice",
            "in": "path",
            "required": true,
            "description": "Nomor invoice order.",
            "schema": {
              "type": "string",
              "example": "INV20260429113629619"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Order ditemukan",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                },
                "example": {
                  "success": true,
                  "message": "OK",
                  "data": {
                    "order": {
                      "invoice_code": "INV20260429113629619",
                      "status": "processing"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Token tidak valid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Order tidak ditemukan atau bukan milik user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "message": "Order tidak ditemukan."
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/me/invoices/{invoice}": {
      "get": {
        "tags": [
          "Invoices"
        ],
        "summary": "Get own invoice",
        "description": "Mengambil detail invoice milik user pemilik token.",
        "security": [
          {
            "userBearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "invoice",
            "in": "path",
            "required": true,
            "description": "Nomor invoice.",
            "schema": {
              "type": "string",
              "example": "INV20260429113629619"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Invoice ditemukan",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                },
                "example": {
                  "success": true,
                  "message": "OK",
                  "data": {
                    "invoice": {
                      "invoice_code": "INV20260429113629619",
                      "type": "order",
                      "payment_status": "paid",
                      "amount": 348
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Token tidak valid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Invoice tidak ditemukan atau bukan milik user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "message": "Invoice tidak ditemukan."
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/me/invoices/{invoice}/status": {
      "get": {
        "tags": [
          "Invoices"
        ],
        "summary": "Get own invoice status",
        "description": "Mengambil status invoice milik user pemilik token.",
        "security": [
          {
            "userBearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "invoice",
            "in": "path",
            "required": true,
            "description": "Nomor invoice.",
            "schema": {
              "type": "string",
              "example": "INV20260429113629619"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Status invoice ditemukan",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                },
                "example": {
                  "success": true,
                  "message": "OK",
                  "data": {
                    "invoice": {
                      "invoice_code": "INV20260429113629619",
                      "type": "order",
                      "payment_status": "paid",
                      "amount": 348
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Token tidak valid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Invoice tidak ditemukan atau bukan milik user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "message": "Invoice tidak ditemukan."
                }
              }
            }
          }
        }
      }
    }
  }
}
