{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "LeuwongRR User API",
  "colors": {
    "primary": "#7eff2f",
    "light": "#7eff2f",
    "dark": "#7eff2f"
  },
  "api": {
    "playground": {
      "display": "interactive",
      "proxy": true
    },
