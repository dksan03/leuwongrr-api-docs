          "errors"
        ]
      },
      {
        "group": "API Reference",
        "pages": [
          "api-reference/introduction"
        ]
      },
      {
        "group": "Endpoint User API",
        "openapi": "api-reference/openapi.json",
        "pages": [
          "GET /api/v1/health",
          "GET /api/v1/me",
          "GET /api/v1/me/balance",
          "GET /api/v1/me/orders",
